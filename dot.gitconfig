[user]
	name = Marcus Vinicius Ferreira
	email = mferreira@webcointernet.com
[color]
	ui = always

[alias]
	ci   = commit
	co   = checkout
	br   = branch
	bra  = branch -a
	st   = status
	stat = status
	sw   = show
	dc   = diff --cached
	ls   = ls-files --stage
	one  = log --pretty='format:%Cgreen%H %Cred%ai %Creset- %s'

[apply]
	whitespace = nowarn

[merge]
	summary = true

