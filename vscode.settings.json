    "vim.shell": "/usr/local/bin/bash",
    "vim.smartRelativeLine": true,
    "vim.statusBarColorControl": true,
    "vim.statusBarColors.normal": "#1e4371",
    "vim.statusBarColors.replace": "#005f5e",
    "vim.statusBarColors.insert": "#730613",
    "vim.targets.smartQuotes.enable": false,
    "vim.textwidth": 120,
    "vim.normalModeKeyBindingsNonRecursive": [
      /* example */
      { "before": ["<C-n>"]        , "commands": [":nohl"] },
      /* shortcuts */
      { "before": ["<leader>", "q"], "commands": [":q!"] },
      { "before": ["<leader>", "n"], "commands": [":set number"] },
      { "before": ["<leader>", "r"], "commands": [":set invrelativenumber"] },
      /* window split */
      { "before": ["<leader>", "w", "j"], "after": ["<C-W>","j"] },
      /* window navigation */
      { "before": ["<leader>", "w", "j"], "after": ["<C-W>","j"] },
      { "before": ["<leader>", "w", "k"], "after": ["<C-W>","k"] },
      { "before": ["<leader>", "w", "l"], "after": ["<C-W>","l"] },
      { "before": ["<leader>", "w", "h"], "after": ["<C-W>","h"] },
      /* tab navigation */
      { "before": ["<leader>",","]      , "after": ["g","t"] },
      { "before": ["<leader>","."]      , "after": ["g","T"] },
      /* sublinhado */
      { "before": ["<leader>", "s", "-"], "after": ["y","y","p","v","$","r","-"] },
      { "before": ["<leader>", "s", "="], "after": ["y","y","p","v","$","r","="] },
      { "before": ["<leader>", "s", "_"], "after": ["y","y","p","v","$","r","_"] },
      { "before": ["<leader>", "s", "*"], "after": ["y","y","p","v","$","r","*"] },
      { "before": ["<leader>", "s", "#"], "after": ["y","y","p","v","$","r","#"] },
      /* join text K ~ J*/
      { "before": ["K"], "after": ["d","d","p","k","J"] } ,
      /* navigation in wrap mode */
      { "before": ["j"], "after": ["g","j"] } ,
      { "before": ["k"], "after": ["g","k"] } ,
      { "before": ["0"], "after": ["g","0"] } ,
      { "before": ["$"], "after": ["g","$","h"] } ,
      /* Re-hardwrap paragraphs of text */
      { "before": ["<leader>", "g", "="], "after": ["g","q","i","p"] },
      /* Cmd-Shift-E: explorer window
        { "before": ["<leader>","f"], "after": ["D-S-e","j","o"] },
        /***/
    ],
    "vscode-neovim.neovimExecutablePaths.darwin": "/usr/local/bin/nvim",
